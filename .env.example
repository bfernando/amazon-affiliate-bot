# Amazon Deals to Twitter/X Bot

# Amazon Associates (Affiliate) Settings
AMAZON_AFFILIATE_TAG=twitterxthetechbff-20
AMAZON_REGION=US  # US, UK, CA, etc.

# X/Twitter API Keys (from developer.twitter.com)
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret
TWITTER_BEARER_TOKEN=your_bearer_token
TWITTER_USER_ID=your_numeric_user_id  # e.g. 123456789 - needed for analytics

# Instagram Graph API (from developers.facebook.com)
# Requires a Facebook Business account with an Instagram Professional account linked.
# Generate a long-lived page access token with:
#   instagram_basic, instagram_manage_insights, instagram_content_publish
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token
INSTAGRAM_ACCOUNT_ID=your_numeric_ig_business_account_id

# TikTok API (from developers.tiktok.com)
# Requires a TikTok for Developers app with Content Posting + Research API access.
TIKTOK_CLIENT_KEY=your_client_key
TIKTOK_CLIENT_SECRET=your_client_secret
TIKTOK_ACCESS_TOKEN=your_oauth2_access_token

# YouTube Data API v3 + Analytics API (from console.cloud.google.com)
# Enable: YouTube Data API v3, YouTube Analytics API
# Create OAuth 2.0 credentials and run the one-time auth flow to get a refresh token.
YOUTUBE_API_KEY=your_api_key          # optional, for read-only public data
YOUTUBE_CLIENT_ID=your_oauth_client_id
YOUTUBE_CLIENT_SECRET=your_oauth_client_secret
YOUTUBE_REFRESH_TOKEN=your_oauth_refresh_token
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxx  # your channel ID

# Deal Settings
DEAL_CATEGORIES=electronics,computers,accessories
MIN_DISCOUNT_PERCENT=20  # Only post deals with 20%+ off
MAX_POSTS_PER_DAY=8
ONLY_AMAZON_SHIPPED=true  # Filter to sold+shipped by Amazon
PRICE_RANGE_MIN=10  # Minimum price in dollars
PRICE_RANGE_MAX=500  # Maximum price in dollars
